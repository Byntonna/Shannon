    <string name="observation_alpn_fallback_title">HTTP/2 fallback observed</string>
    <string name="observation_alpn_fallback_summary">Multiple endpoints negotiated HTTP/1.1 instead of h2. This can be caused by ALPN interference or TLS interception.</string>
    <string name="observation_quic_blocking_title">Possible QUIC blocking detected</string>
    <string name="observation_quic_blocking_summary">HTTP/2 over TCP succeeded, but multiple HTTP/3 probes failed before negotiating h3. This can indicate UDP or QUIC filtering.</string>
    <string name="observation_http3_fallback_title">HTTP/3 fallback observed</string>
    <string name="observation_http3_fallback_summary">A tested endpoint completed the request but negotiated HTTP/2 or HTTP/1.1 instead of h3.</string>
    <string name="observation_http3_unconfirmed_title">HTTP/3 could not be confirmed</string>
    <string name="observation_http3_unconfirmed_summary">HTTPS over TCP succeeded, but Shannon could not confirm h3 negotiation across multiple endpoints.</string>
    <string name="observation_websocket_failed_title">WebSocket upgrade failed while HTTPS worked</string>
    <string name="observation_websocket_failed_summary">The network allowed regular HTTPS traffic, but the WebSocket upgrade did not complete. This can indicate proxy or application-layer filtering.</string>
    <string name="observation_provider_specific_title">Provider-specific differences detected</string>
    <string name="observation_provider_specific_summary">Not all endpoints behaved the same way. This can reflect selective filtering, CDN differences, or provider-specific routing problems.</string>
    <string name="observation_no_clear_interference_title">No clear interference detected</string>
    <string name="observation_no_clear_interference_summary">The current run did not match any strong DPI or middlebox heuristics.</string>
    <string name="observation_inconclusive_title">Inconclusive</string>
    <string name="observation_inconclusive_summary">Some providers showed mixed SNI or certificate behavior, but the overall pattern was not strong enough for a reliable interference conclusion.</string>
    <string name="observation_tls_interception_title">Possible TLS interception</string>
    <string name="observation_tls_interception_summary">At least one endpoint presented a certificate issuer that looks like a proxy, filter, or security product.</string>
    <string name="observation_tls_downgrade_title">Possible TLS downgrade</string>
    <string name="observation_tls_downgrade_summary">Some endpoints negotiated TLS 1.2 even though a dedicated TLS 1.3 handshake also succeeded.</string>
    <string name="observation_unusual_chain_title">Certificate chain looks shorter than expected</string>
    <string name="observation_unusual_chain_summary">One or more endpoints presented a very short certificate chain. This can be normal, but it is worth double-checking if other TLS signals also look unusual.</string>
    <string name="observation_no_tls_anomalies_title">No TLS anomalies detected</string>
    <string name="observation_no_tls_anomalies_summary">TLS versions, certificate issuers, and handshake metadata look normal for the tested endpoints.</string>
    <string name="tls_observation_inconclusive_title">Inconclusive TLS result</string>
    <string name="tls_observation_inconclusive_summary">No successful TLS handshakes were collected for this run, so Shannon could not draw a reliable conclusion.</string>
    <string name="observation_sni_filtering_pattern_title">Selective TLS failure on the normal SNI</string>
    <string name="observation_sni_filtering_pattern_summary">DNS and TCP succeeded for the baseline connection, but TLS failed only for the normal SNI while other variants still completed.</string>
    <string name="observation_mixed_sni_title">Mixed SNI behavior</string>
    <string name="observation_mixed_sni_summary">The baseline TLS handshake failed after TCP, but non-default SNI variants produced mixed outcomes that are not conclusive on their own.</string>
    <string name="observation_baseline_untrusted_title">Baseline certificate chain was not trusted</string>
    <string name="observation_baseline_untrusted_summary">The normal SNI handshake completed, but the certificate chain did not validate against the Android system trust store.</string>
    <string name="observation_baseline_hostname_mismatch_title">Baseline certificate did not match the hostname</string>
    <string name="observation_baseline_hostname_mismatch_summary">The normal SNI handshake completed, but the presented certificate did not match the requested hostname.</string>
    <string name="observation_repeated_untrusted_issuer_title">Same untrusted issuer seen across providers</string>
    <string name="observation_repeated_untrusted_issuer_summary">Multiple providers returned baseline certificates issued by the same untrusted authority, which is consistent with TLS interception.</string>
    <string name="observation_repeated_suspicious_fingerprint_title">Same suspicious certificate fingerprint seen across providers</string>
    <string name="observation_repeated_suspicious_fingerprint_summary">Multiple providers returned the same baseline certificate fingerprint together with other unusual TLS signals.</string>
    <string name="observation_sni_filtering_detected_title">Possible SNI filtering detected</string>
    <string name="observation_sni_filtering_detected_summary">At least one provider failed the TLS handshake only on the normal SNI while other SNI variants still completed.</string>
    <string name="observation_mitm_title">MITM suspected</string>
    <string name="observation_mitm_summary">Multiple providers showed the same uncommon baseline certificate pattern.</string>
    <string name="observation_no_clear_sni_title">No clear SNI interference detected</string>
    <string name="observation_no_clear_sni_summary">Baseline handshakes completed normally and the collected variant differences did not form a strong filtering or interception pattern.</string>

